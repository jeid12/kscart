# Backend server port
PORT=4000

# PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kasicart

# Comma-separated list of allowed origins for CORS (the frontend URL)
CORS_ORIGIN=http://localhost:3000

# MoMo USSD template used to build the payment dial string.
# Placeholders {code} and {amount} are replaced at checkout time.
# NOTE: Confirm the exact syntax with current MTN Rwanda *182# merchant docs.
MOMO_USSD_TEMPLATE=*182*8*1*{code}*{amount}#

# --- Authentication ---
# Use a long random string in production (e.g. `openssl rand -hex 32`).
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# --- Cloudinary (image uploads) ---
# Easiest: copy the single CLOUDINARY_URL from your Cloudinary dashboard.
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Or set the parts individually instead of CLOUDINARY_URL:
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=kasicart
